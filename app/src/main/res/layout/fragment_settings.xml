<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settingsFragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.SettingsFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:background="#FFFFFF"
                app:cardBackgroundColor="#3949AB"
                app:cardCornerRadius="6dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <TextView
                            android:id="@+id/textViewUsername"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerHorizontal="true"
                            android:padding="12dp"
                            android:paddingBottom="8dp"
                            android:text="USERNAME PLACEHOLDER"
                            android:textAlignment="viewStart"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp" />

                        <TextView
                            android:id="@+id/textViewEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/textViewUsername"
                            android:layout_centerHorizontal="true"
                            android:paddingBottom="16dp"
                            android:text="EMAIL PLACEHOLDER"
                            android:textAlignment="viewStart"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp" />

                        <TextView
                            android:id="@+id/textViewPosted"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/textViewEmail"
                            android:layout_centerHorizontal="true"
                            android:padding="6dp"
                            android:text="Messages Posted: 0"
                            android:textColor="#FFFFFF" />

                        <TextView
                            android:id="@+id/textViewTotalKept"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/textViewPosted"
                            android:layout_centerHorizontal="true"
                            android:padding="6dp"
                            android:text="Messages Kept: 0"
                            android:textColor="#FFFFFF" />

                        <TextView
                            android:id="@+id/textViewTotalSeen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/textViewTotalKept"
                            android:layout_centerHorizontal="true"
                            android:padding="6dp"
                            android:text="Messages Seen: 0"
                            android:textColor="#FFFFFF" />

                        <TextView
                            android:id="@+id/textViewTotalComments"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/textViewTotalSeen"
                            android:layout_centerHorizontal="true"
                            android:padding="6dp"
                            android:text="Comments Made: 0"
                            android:textColor="#FFFFFF" />

                        <TextView
                            android:id="@+id/textViewMyViews"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/textViewTotalComments"
                            android:layout_centerHorizontal="true"
                            android:padding="6dp"
                            android:text="Views on My Messages: 0"
                            android:textColor="#FFFFFF" />

                        <TextView
                            android:id="@+id/textViewMyKeeps"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/textViewMyViews"
                            android:layout_centerHorizontal="true"
                            android:padding="6dp"
                            android:text="Keeps on My Messages: 0"
                            android:textColor="#FFFFFF" />

                        <TextView
                            android:id="@+id/textViewMyComments"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/textViewMyKeeps"
                            android:layout_centerHorizontal="true"
                            android:paddingTop="8dp"
                            android:paddingBottom="16dp"
                            android:text="Comments on My Messages: 0"
                            android:textColor="#FFFFFF" />

                        <Button
                            android:id="@+id/buttonLogout"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/textViewMyComments"
                            android:layout_centerHorizontal="true"
                            android:backgroundTint="#D81B60"
                            android:elevation="4dp"
                            android:paddingTop="10dp"
                            android:text="@string/log_out"
                            android:textSize="18sp" />
                    </RelativeLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:background="#FFFFFF"
                app:cardBackgroundColor="#5E35B1"
                app:cardCornerRadius="6dp"
                app:cardElevation="6dp">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/textViewMapFilter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerHorizontal="true"
                            android:paddingBottom="6dp"
                            android:text="What's on your Map"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            tools:layout_editor_absoluteX="30dp"
                            tools:layout_editor_absoluteY="172dp" />

                        <CheckBox
                            android:id="@+id/checkBoxReveal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/textViewMapFilter"
                            android:checked="true"
                            android:text="Reveal Range"
                            android:textColor="#FFFFFF"
                            tools:layout_editor_absoluteX="30dp"
                            tools:layout_editor_absoluteY="309dp" />

                        <CheckBox
                            android:id="@+id/checkBoxSeeCircle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/checkBoxReveal"
                            android:checked="true"
                            android:text="See Range"
                            android:textColor="#FFFFFF"
                            tools:layout_editor_absoluteX="30dp"
                            tools:layout_editor_absoluteY="379dp" />

                        <CheckBox
                            android:id="@+id/checkBoxOwn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/checkBoxSeeCircle"
                            android:checked="true"
                            android:text="My Messages"
                            android:textColor="#FFFFFF"
                            tools:layout_editor_absoluteX="43dp"
                            tools:layout_editor_absoluteY="667dp" />

                        <CheckBox
                            android:id="@+id/checkBoxKept"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/checkBoxOwn"
                            android:checked="true"
                            android:text="Following Messages"
                            android:textColor="#FFFFFF"
                            tools:layout_editor_absoluteX="33dp"
                            tools:layout_editor_absoluteY="443dp" />

                        <CheckBox
                            android:id="@+id/checkBoxSeen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/checkBoxKept"
                            android:checked="true"
                            android:text="Seen Messages"
                            android:textColor="#FFFFFF"
                            tools:layout_editor_absoluteX="72dp"
                            tools:layout_editor_absoluteY="518dp" />

                        <CheckBox
                            android:id="@+id/checkBoxUnseen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/checkBoxSeen"
                            android:checked="true"
                            android:text="Unseen Messages"
                            android:textColor="#FFFFFF"
                            tools:layout_editor_absoluteX="43dp"
                            tools:layout_editor_absoluteY="610dp" />


                        <com.google.android.gms.maps.MapView
                            android:id="@+id/mapViewSettings"
                            android:layout_width="180dp"
                            android:layout_height="290dp"
                            android:layout_below="@id/textViewMapFilter"
                            android:layout_alignParentRight="true" />

                        <ImageButton
                            android:id="@+id/imageButtonRevealHelp"
                            android:layout_width="19dp"
                            android:layout_height="27dp"
                            android:layout_below="@id/textViewMapFilter"
                            android:layout_marginLeft="3dp"
                            android:layout_marginTop="4dp"
                            android:layout_toRightOf="@id/checkBoxReveal"
                            android:backgroundTint="#4356CC"
                            android:elevation="2dp"
                            android:src="@android:drawable/ic_menu_help" />

                        <ImageButton
                            android:id="@+id/imageButtonSeeHelp"
                            android:layout_width="19dp"
                            android:layout_height="27dp"
                            android:layout_below="@id/checkBoxReveal"
                            android:layout_marginLeft="3dp"
                            android:layout_marginTop="4dp"
                            android:layout_toRightOf="@id/checkBoxSeeCircle"
                            android:backgroundTint="#5266E3"
                            android:elevation="2dp"
                            android:src="@android:drawable/ic_menu_help" />

                        <ImageButton
                            android:id="@+id/imageButtonOwnHelp"
                            android:layout_width="19dp"
                            android:layout_height="27dp"
                            android:layout_below="@id/checkBoxSeeCircle"
                            android:layout_marginLeft="3dp"
                            android:layout_marginTop="4dp"
                            android:layout_toRightOf="@id/checkBoxOwn"
                            android:backgroundTint="#039BE5"
                            android:elevation="2dp"
                            android:src="@android:drawable/ic_menu_help" />

                        <ImageButton
                            android:id="@+id/imageButtonKeptHelp"
                            android:layout_width="19dp"
                            android:layout_height="27dp"
                            android:layout_below="@id/checkBoxOwn"
                            android:layout_marginLeft="3dp"
                            android:layout_marginTop="4dp"
                            android:layout_toRightOf="@id/checkBoxKept"
                            android:backgroundTint="#FB8C00"
                            android:elevation="2dp"
                            android:src="@android:drawable/ic_menu_help" />

                        <ImageButton
                            android:id="@+id/imageButtonSeenHelp"
                            android:layout_width="19dp"
                            android:layout_height="27dp"
                            android:layout_below="@id/checkBoxKept"
                            android:layout_marginLeft="3dp"
                            android:layout_marginTop="4dp"
                            android:layout_toRightOf="@id/checkBoxSeen"
                            android:backgroundTint="#43A047"
                            android:elevation="2dp"
                            android:src="@android:drawable/ic_menu_help" />

                        <ImageButton
                            android:id="@+id/imageButtonUnseenHelp"
                            android:layout_width="19dp"
                            android:layout_height="27dp"
                            android:layout_below="@id/checkBoxSeen"
                            android:layout_marginLeft="3dp"
                            android:layout_marginTop="4dp"
                            android:layout_toRightOf="@id/checkBoxUnseen"
                            android:backgroundTint="#7CB342"
                            android:elevation="2dp"
                            android:src="@android:drawable/ic_menu_help" />


                    </RelativeLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>


